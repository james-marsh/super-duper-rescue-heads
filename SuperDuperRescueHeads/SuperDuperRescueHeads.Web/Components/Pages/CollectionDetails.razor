@page "/collections/{CollectionId:guid}"
@rendermode InteractiveServer
@using SuperDuperRescueHeads.Web.Services
@inject ICollectionService CollectionService
@inject IItemService ItemService
@inject NavigationManager Navigation
@attribute [Authorize]

<PageTitle>@(collection?.Name ?? "Collection Details")</PageTitle>

<div class="container mt-4">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Loading collection...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @errorMessage
        </div>
        <a href="/collections" class="btn btn-primary">Back to Collections</a>
    }
    else if (collection != null)
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2>@collection.Name</h2>
                <p><span class="badge bg-primary">@collection.ItemType</span></p>
                @if (!string.IsNullOrEmpty(collection.Description))
                {
                    <p class="text-muted">@collection.Description</p>
                }
            </div>
            <div class="btn-group" role="group">
                <a href="/collections/@collection.CollectionId/edit" class="btn btn-outline-primary">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                <a href="/collections" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3">
                        <strong>Total Items:</strong>
                    </div>
                    <div class="col-md-9">
                        @collection.ItemCount
                    </div>
                </div>
                <hr />
                <div class="row">
                    <div class="col-md-3">
                        <strong>Created:</strong>
                    </div>
                    <div class="col-md-9">
                        @collection.CreatedAt.ToLocalTime().ToString("MMMM dd, yyyy 'at' h:mm tt")
                    </div>
                </div>
                <hr />
                <div class="row">
                    <div class="col-md-3">
                        <strong>Last Updated:</strong>
                    </div>
                    <div class="col-md-9">
                        @collection.UpdatedAt.ToLocalTime().ToString("MMMM dd, yyyy 'at' h:mm tt")
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Items in this Collection</h5>
                <a href="/collections/@collection.CollectionId/items/create" class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-circle"></i> Add Item
                </a>
            </div>
            <div class="card-body">
                @if (isLoadingItems)
                {
                    <div class="text-center py-3">
                        <div class="spinner-border spinner-border-sm" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else if (items.Count == 0)
                {
                    <div class="alert alert-info" role="alert">
                        <i class="bi bi-info-circle"></i> No items in this collection yet. Click "Add Item" to get started!
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Acquisition Date</th>
                                    <th>Created</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in items)
                                {
                                    <tr>
                                        <td>
                                            <strong>@item.Name</strong>
                                            @if (!string.IsNullOrEmpty(item.Notes))
                                            {
                                                <br />
                                                <small class="text-muted">@item.Notes</small>
                                            }
                                        </td>
                                        <td>
                                            @if (item.AcquisitionDate.HasValue)
                                            {
                                                @item.AcquisitionDate.Value.ToLocalTime().ToString("MMM dd, yyyy")
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>@item.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a href="/collections/@collection.CollectionId/items/@item.ItemId/edit" class="btn btn-outline-primary">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <button class="btn btn-outline-danger" @onclick="() => ConfirmDeleteItem(item)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@if (itemToDelete != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDeleteItem"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete the item "<strong>@itemToDelete.Name</strong>"?</p>
                    <p class="text-danger">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDeleteItem">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteItem" disabled="@isDeletingItem">
                        @if (isDeletingItem)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        }
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid CollectionId { get; set; }

    private CollectionDto? collection;
    private List<ItemDto> items = new();
    private bool isLoading = true;
    private bool isLoadingItems = false;
    private bool isDeletingItem = false;
    private string? errorMessage;
    private ItemDto? itemToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadCollection();
        if (collection != null)
        {
            await LoadItems();
        }
    }

    private async Task LoadCollection()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            collection = await CollectionService.GetCollectionAsync(CollectionId);

            if (collection == null)
            {
                errorMessage = "Collection not found.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load collection: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadItems()
    {
        isLoadingItems = true;

        try
        {
            items = await ItemService.GetItemsAsync(CollectionId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load items: {ex.Message}";
        }
        finally
        {
            isLoadingItems = false;
        }
    }

    private void ConfirmDeleteItem(ItemDto item)
    {
        itemToDelete = item;
    }

    private void CancelDeleteItem()
    {
        itemToDelete = null;
    }

    private async Task DeleteItem()
    {
        if (itemToDelete == null || collection == null) return;

        isDeletingItem = true;

        try
        {
            var success = await ItemService.DeleteItemAsync(collection.CollectionId, itemToDelete.ItemId);

            if (success)
            {
                items.Remove(itemToDelete);
                itemToDelete = null;
            }
            else
            {
                errorMessage = "Failed to delete item. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting item: {ex.Message}";
        }
        finally
        {
            isDeletingItem = false;
        }
    }
}
