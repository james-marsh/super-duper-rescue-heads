@page "/logout"
@rendermode InteractiveServer
@using SuperDuperRescueHeads.Web.Services
@inject IAuthenticationService AuthService
@inject CustomAuthStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Logging out...</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card">
                <div class="card-body py-5">
                    @if (isLoggingOut)
                    {
                        <div class="spinner-border text-primary mb-3" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <h4>Logging you out...</h4>
                        <p class="text-muted">Please wait while we log you out securely.</p>
                    }
                    else
                    {
                        <i class="bi bi-check-circle text-success" style="font-size: 3rem;"></i>
                        <h4 class="mt-3">You've been logged out</h4>
                        <p class="text-muted">Thank you for using SuperDuperRescueHeads!</p>
                        <a href="/login" class="btn btn-primary mt-3">Log In Again</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private bool isLoggingOut = true;

    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(500); // Brief delay for user experience
        await HandleLogout();
    }

    private async Task HandleLogout()
    {
        try
        {
            await AuthService.LogoutAsync();
            AuthStateProvider.NotifyUserLogout();
        }
        catch
        {
            // Even if logout fails on the server, clear local state
            AuthStateProvider.NotifyUserLogout();
        }
        finally
        {
            isLoggingOut = false;
            await Task.Delay(1500); // Show success message briefly
            Navigation.NavigateTo("/login", forceLoad: true);
        }
    }
}
